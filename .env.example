
# Weekly pipeline execution
# The API submits a finite Nebius Job. The Job starts local vLLM, runs the full
# pipeline, persists results to Object Storage, and exits.
STACKTWIN_PIPELINE_EXECUTION=nebius_job
STACKTWIN_JOB_IMAGE=cr.eu-north1.nebius.cloud/e00wkter9vcdmapban/stacktwin-job@sha256:9a219ea40337cca143becbd6e3d9bf48b28c2ccbc4ebc7bfb550af87f689b0d3
STACKTWIN_JOB_SUBNET_ID=your_subnet_id
STACKTWIN_JOB_ENV_FILE=.env
STACKTWIN_JOB_PLATFORM=gpu-l40s-a
STACKTWIN_JOB_PRESET=1gpu-8vcpu-32gb
STACKTWIN_JOB_PREEMPTIBLE=true
STACKTWIN_JOB_DISK_SIZE=100Gi
STACKTWIN_JOB_SHM_SIZE=16Gi
STACKTWIN_JOB_TIMEOUT=2h

# Model routing. Test mode forces NEBIUS_MODEL_TEST for every LLM call.
# Production mode reserves Hermes for map/preparation work and large Qwen for
# reduce/generation work; it requires separate model phases and larger presets.
NEBIUS_MODEL_MODE=test
NEBIUS_MODEL_TEST=Qwen/Qwen3-0.6B
NEBIUS_MODEL_MAP=NousResearch/Hermes-4-70B
NEBIUS_MODEL_RED=Qwen/Qwen3-235B-A22B-Thinking-2507

# Storage backend: json for local demos, nebius for production
STORAGE_BACKEND=nebius

# Local JSON storage
PROFILES_DIR=profiles
OUTPUTS_DIR=outputs

# Nebius Object Storage
# Create a bucket and service-account access key before selecting STORAGE_BACKEND=nebius.
NEBIUS_S3_BUCKET=your_stacktwin_bucket
NEBIUS_S3_REGION=eu-north1
NEBIUS_S3_ENDPOINT=https://storage.eu-north1.nebius.cloud
NEBIUS_S3_ACCESS_KEY_ID=your_access_key_id
NEBIUS_S3_SECRET_ACCESS_KEY=your_secret_access_key
NEBIUS_S3_PREFIX=stacktwin

# Optional isolated prefix used by live bucket contract tests
NEBIUS_S3_TEST_PREFIX=stacktwin-tests
RUN_NEBIUS_STORAGE_TESTS=false

# Public demo learner used by the compiled classroom UI
NEXT_PUBLIC_STACKTWIN_USER_ID=demo@stacktwin.dev
# Set true only when intentionally using the hardcoded classroom fixture.
NEXT_PUBLIC_STACKTWIN_DEMO_MODE=false

# Pipeline configuration
# SOURCE_LIMIT=50     # articles fetched per source (default 50)
# DIGEST_SIZE=10      # articles in the weekly digest (default 10)

# Fast test profile — uncomment for quick end-to-end runs
# SOURCE_LIMIT=5
# DIGEST_SIZE=5
