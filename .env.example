
# Weekly pipeline execution. Both application modes submit finite Nebius Jobs;
# workers persist pipeline artifacts in Object Storage and exit when complete.
STACKTWIN_JOB_IMAGE=cr.eu-north1.nebius.cloud/e00wkter9vcdmapban/stacktwin-job:dev
STACKTWIN_JOB_SUBNET_ID=your_subnet_id
STACKTWIN_JOB_ENV_FILE=.env
# Local app mode: economical one-GPU Qwen Jobs.
STACKTWIN_LOCAL_JOB_PLATFORM=gpu-l40s-a
STACKTWIN_LOCAL_JOB_PRESET=1gpu-8vcpu-32gb
STACKTWIN_LOCAL_JOB_TENSOR_PARALLEL_SIZE=1
STACKTWIN_LOCAL_JOB_PREEMPTIBLE=true
STACKTWIN_LOCAL_JOB_DISK_SIZE=100Gi
STACKTWIN_LOCAL_JOB_SHM_SIZE=16Gi
STACKTWIN_LOCAL_JOB_TIMEOUT=2h

# Cloud app mode: the designated production models require eight GPUs and
# tensor parallelism. This is a materially more expensive execution tier.
STACKTWIN_CLOUD_JOB_PLATFORM=gpu-h100-sxm
STACKTWIN_CLOUD_JOB_PRESET=8gpu-128vcpu-1600gb
STACKTWIN_CLOUD_JOB_TENSOR_PARALLEL_SIZE=8
STACKTWIN_CLOUD_JOB_PREEMPTIBLE=false
STACKTWIN_CLOUD_JOB_DISK_SIZE=600Gi
STACKTWIN_CLOUD_JOB_SHM_SIZE=64Gi
STACKTWIN_CLOUD_JOB_TIMEOUT=4h

# App mode controls the model tier. Local uses Qwen for every Job phase; cloud
# uses Hermes for map work and the designated Qwen model for reduce/generation.
STACKTWIN_APP_MODE=local
NEBIUS_MODEL_TEST=Qwen/Qwen3-0.6B
NEBIUS_MODEL_MAP=NousResearch/Hermes-4-70B
NEBIUS_MODEL_RED=Qwen/Qwen3-235B-A22B-Thinking-2507

# Local JSON storage
PROFILES_DIR=profiles
OUTPUTS_DIR=outputs

# Nebius Object Storage
# Required for Job workflows in both modes. Local mode also uses them to hydrate
# its local cache from Job outputs.
NEBIUS_S3_BUCKET=your_stacktwin_bucket
NEBIUS_S3_REGION=eu-north1
NEBIUS_S3_ENDPOINT=https://storage.eu-north1.nebius.cloud
NEBIUS_S3_ACCESS_KEY_ID=your_access_key_id
NEBIUS_S3_SECRET_ACCESS_KEY=your_secret_access_key
NEBIUS_S3_PREFIX=stacktwin

# Optional isolated prefix used by live bucket contract tests
NEBIUS_S3_TEST_PREFIX=stacktwin-tests
RUN_NEBIUS_STORAGE_TESTS=false

# Public demo learner used by the compiled classroom UI
NEXT_PUBLIC_STACKTWIN_USER_ID=demo@stacktwin.dev
# Set true only when intentionally using the hardcoded classroom fixture.
NEXT_PUBLIC_STACKTWIN_DEMO_MODE=false

# Simple app access gate. Set a strong value in .env before deploying.
STACKTWIN_APP_PASSWORD=change-this-before-deploy
# Set true for HTTPS deployments; leave false for local http://127.0.0.1 development.
STACKTWIN_COOKIE_SECURE=false

# Pipeline configuration
# SOURCE_LIMIT=50     # articles fetched per source (default 50)
# DIGEST_SIZE=10      # articles in the weekly digest (default 10)

# Fast test profile — uncomment for quick end-to-end runs
# SOURCE_LIMIT=5
# DIGEST_SIZE=5
